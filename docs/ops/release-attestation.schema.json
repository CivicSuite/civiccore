{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://civicsuite.dev/schemas/release-attestation.v1.json",
  "title": "CivicSuite Release Attestation",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "subject", "build", "artifacts", "evidence_bundles"],
  "properties": {
    "schema_version": {
      "const": 1,
      "description": "Versioned CivicSuite release-attestation contract."
    },
    "subject": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repo",
        "tag",
        "tag_ref_type",
        "tag_ref_sha",
        "target_commit",
        "target_tree"
      ],
      "properties": {
        "repo": {"type": "string", "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$"},
        "tag": {"type": "string", "pattern": "^v[0-9]+\\.[0-9]+\\.[0-9]+.*$"},
        "tag_ref_type": {"type": "string", "enum": ["commit", "tag"]},
        "tag_ref_sha": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
        "target_commit": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
        "target_tree": {"type": "string", "pattern": "^[0-9a-f]{40}$"}
      }
    },
    "build": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "workflow_identity",
        "workflow_path",
        "workflow_run_id",
        "oidc_issuer"
      ],
      "properties": {
        "workflow_identity": {
          "type": "string",
          "description": "Exact Sigstore certificate identity, including repo, workflow path, and tag ref."
        },
        "workflow_path": {"type": "string", "const": ".github/workflows/release.yml"},
        "workflow_run_id": {"type": "string", "minLength": 1},
        "oidc_issuer": {
          "type": "string",
          "const": "https://token.actions.githubusercontent.com"
        }
      }
    },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "sha256"],
        "properties": {
          "name": {"type": "string", "minLength": 1},
          "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
        }
      }
    },
    "evidence_bundles": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "sha256"],
        "properties": {
          "name": {"type": "string", "minLength": 1},
          "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
        }
      }
    }
  }
}
